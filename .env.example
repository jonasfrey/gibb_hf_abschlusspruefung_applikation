# Konfiguration für den Docker-Compose-Stack (DEP).
# Kopiere diese Datei nach .env und passe die Werte an.

# MariaDB Root-Passwort (nur intern, kein Port nach aussen veröffentlicht)
MYSQL_ROOT_PASSWORD=changeme

# Applikations-Datenbank und -Benutzer (vom Backend genutzt)
MYSQL_DATABASE=UBahn
MYSQL_USER=admin
MYSQL_PASSWORD=changeme
